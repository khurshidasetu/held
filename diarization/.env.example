# Copy to .env on the VPS and edit. Never commit the real .env.

# Shared secret. Must match DIARIZATION_SERVICE_API_KEY in the Next.js app.
# Generate with: openssl rand -hex 32
DIARIZATION_API_KEY="change-me-to-a-long-random-string"

# Hugging Face user-access token, with "Read" access to the pyannote model.
# Accept the model terms at:
#   https://hf.co/pyannote/speaker-diarization-3.1
#   https://hf.co/pyannote/segmentation-3.0
# then create a token at https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN="hf_..."

# Optional overrides.
# DIARIZATION_PIPELINE="pyannote/speaker-diarization-3.1"
# MAX_AUDIO_BYTES="524288000"
