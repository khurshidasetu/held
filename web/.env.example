# ─────────────────────────────────────────────────────────────
# Held — Web app environment variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Public app URL (used in emails and PWA scope). No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Database (MySQL) ───
# Any MySQL 8.0+ instance works: local install, Docker, AWS RDS, PlanetScale,
# Railway, Hetzner, etc. The connection pool size can be tuned via
# DATABASE_POOL_SIZE (default 10).
#
# Format: mysql://<user>:<password>@<host>:<port>/<database>
# Add ?ssl={"rejectUnauthorized":true} for managed hosts that require TLS.
DATABASE_URL="mysql://root:root@localhost:3306/held"
# DATABASE_POOL_SIZE="10"

# ─── Clerk (auth) ───
# Get from https://dashboard.clerk.com → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Where Clerk's hosted pages live in our app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# ─── Storage ───
# "local" → writes under LOCAL_STORAGE_DIR; reads via /api/storage/<key>?...
#           with an HMAC-signed expiring token (no AWS account needed).
# "s3"    → uses the AWS_* vars below.
STORAGE_DRIVER="local"

# When STORAGE_DRIVER="local":
LOCAL_STORAGE_DIR="./storage"
# URL the *browser* uses to fetch files (speaker sample playback in the
# popup, etc.). Defaults to NEXT_PUBLIC_APP_URL if omitted.
# LOCAL_STORAGE_BASE_URL="http://localhost:3000"
# URL the *diarization service* uses to fetch files. When the diarization
# container runs in Docker on the same machine, set this to
# http://host.docker.internal:3000 so it can reach the dev server on the host.
INTERNAL_STORAGE_BASE_URL="http://host.docker.internal:3000"
# Optional separate signing key. Defaults to INTERNAL_WORKER_SECRET.
# LOCAL_STORAGE_SIGN_SECRET=""

# When STORAGE_DRIVER="s3":
# Bucket must allow PUTs from the server, and reads via presigned GETs.
AWS_REGION="us-east-1"
AWS_S3_BUCKET="held-prod"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."

# ─── Diarization service (self-hosted FastAPI / pyannote) ───
# Set this to the public URL of the diarization VPS.
DIARIZATION_SERVICE_URL="http://localhost:8000"
# Shared secret sent as X-API-Key when calling the diarization service.
DIARIZATION_SERVICE_API_KEY="change-me-to-a-long-random-string"

# ─── Speech-to-text provider ───
# "mock" (default) — synthesizes a placeholder transcript spread across the
#   audio's real duration. No API key needed. Lets you exercise the full
#   pipeline without a Cartesia account.
# "cartesia"        — real Ink-Whisper STT over WebSocket. Requires the key
#   below.
STT_PROVIDER="mock"
CARTESIA_API_KEY="sk_car_..."   # only used when STT_PROVIDER="cartesia"
# Optional: pin a specific model or language.
#
# Empty CARTESIA_LANGUAGE (default) tells Ink-Whisper to auto-detect.
# In practice, auto-detect often mis-routes single-language non-English
# speech back through the English lexicon (Bangla speech ends up as
# nonsense English words). If every meeting in this deployment is a
# specific language, pin it via a BCP-47 tag:
#
#   CARTESIA_LANGUAGE="bn"    # Bangla
#   CARTESIA_LANGUAGE="hi"    # Hindi
#   CARTESIA_LANGUAGE="en"    # English
#
# For TRUE Bangla+English code-switching in the same meeting,
# Cartesia Ink-Whisper isn't the right tool — use OpenAI Whisper
# large-v3 (or the Whisper API) which handles code-switch natively.
# CARTESIA_MODEL="ink-whisper"
# CARTESIA_LANGUAGE=""

# ─── LLM provider (meeting summaries) ───
# "openrouter" (default) — one key proxies to Claude (and many others)
# "anthropic"            — direct Anthropic API
LLM_PROVIDER="openrouter"

# When LLM_PROVIDER="openrouter":
# Get from https://openrouter.ai → Keys. The default model is
# anthropic/claude-sonnet-4.5; override with OPENROUTER_MODEL.
OPENROUTER_API_KEY="sk-or-v1-..."
# OPENROUTER_MODEL="anthropic/claude-sonnet-4.5"

# When LLM_PROVIDER="anthropic":
# Get from https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-5"

# ─── Postmark (transactional email) ───
# Server API Token (UUID format). From your Postmark dashboard:
#   Servers → <your server> → API Tokens.
POSTMARK_API_KEY="..."
# Verified Sender Signature (or address on a verified domain). Postmark
# rejects sends with an unverified From address.
POSTMARK_SENDER="no-reply@example.com"
# Optional display name. Renders as: `Held <no-reply@…>`.
POSTMARK_FROM_NAME="Held"

# ─── Internal worker shared secret ───
# Used to authenticate the fire-and-forget /api/meetings/[id]/process call.
INTERNAL_WORKER_SECRET="change-me-to-a-long-random-string"
