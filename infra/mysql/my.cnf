# MySQL config for the Minutely container.
# Merged with /etc/mysql/my.cnf at startup.

[mysqld]
# Unicode everywhere. utf8mb4 is a strict superset of UTF-8 — required for
# 4-byte chars (emoji in meeting titles, attendee names, transcript text).
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

# Store all timestamps in UTC so the app can do timezone math without surprises.
default-time-zone = '+00:00'

# Reasonable defaults for a single-app workload. Bump max_connections if you
# end up running the diarization worker, the web app, and migrations against
# the same instance simultaneously.
max_connections = 200
max_allowed_packet = 64M

# Enable strict mode (default in MySQL 8, but make it explicit).
sql_mode = STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,ERROR_FOR_DIVISION_BY_ZERO

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
